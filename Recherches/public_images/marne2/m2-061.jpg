<!DOCTYPE html>
<html>
<head>
	<title>Page Not Found</title>
	<meta charset="utf-8">
	<link rel='stylesheet' href='https://media.lib.byu.edu/assets/css/loader/hbll-4.1' type='text/css' />
	<link rel="shortcut icon" href="https://lib.byu.edu/favicon.ico?v24601">

	<style type="text/css">
		body {
			background: hsl(216, 47%, 20%);
			font-family: Source Sans Pro, Helvetica, Arial, sans-serif;
			font-size: 1.5rem;
			margin: 0;
		}

		#page {
			margin: 15px auto 50px;
			max-width: 450px;
			width: 95%;
		}

		#page header h1 {
			font-size: 1.5em;
			font-weight: normal;
			margin: 0 0 .5em 0;
		}

		#page header h1 a.logo {
			color: #fff;
			display: block;
			margin: 30px auto;
			max-width: 120px;
			text-decoration: none;
		}

		#page header h1 a.logo img {
			max-width: 120px;
		}

		#content {
			background: #fff;
			border-radius: 5px;
			overflow: hidden;
			padding: 25px;
		}

		#content #failquail {
			cursor: help;
			position: relative;
		}

		#content #failquail img {
			display: block;
			margin: 30px auto 10px;
			max-width: 75px;
		}

		.easter-happy-day {
			background: #fff;
			border-radius: 100%;
			box-shadow: 0 0 15px;
			opacity: 0;
			margin: 0px auto;
			max-width: 280px;
			left: 0;
			padding: 75px 34px;
			position: absolute;
			right: 0;
			text-align: center;
			top: -137px;
			z-index: 50000;
		}

		.easter-happy-day h3 {
			color: hsl(216, 100%, 50%);
			font-size: 1.4em;
			line-height: 1.3em;
			margin-bottom: 1em;
		}

		#message {
			color: #333;
			line-height: 1.4em;
		}

		#message h2 {
			color: #be1010;
			font-size: 1.3em;
			font-weight: 600;
			margin: 0 0 1em 0;
			text-align: center;
		}

		#message a {
			color: #4c7fcc;
		}

		#message p {
			font-size: 1.2em;	
			line-height: 1.3em;
			text-align: center;
		}

		@media screen and (min-width: 500px) {
			#page {
				margin-top: 50px;
				max-width: 600px;
			}

			#message h2 {
				font-size: 1.8em;
			}

			#content {
				padding: 50px 75px;
			}

			#content #failquail img {
				margin: 50px auto 30px;
				opacity: 1.0;
			}

			#content #failquail:hover img {
				animation-duration: 8s;
				animation-name: mypreciousssss;
				animation-iteration-count: infinite;
			}

			#content #failquail:hover .easter-happy-day {
				animation-duration: 8s;
				animation-name: gollumgollum;
				animation-iteration-count: infinite;
			}

			@keyframes mypreciousssss {
				0% {
					opacity: 1.0;
				}
				30% {
					opacity: 1.0;
				}
				40% {
					opacity: 0.0;
				}
				90% {
					opacity: 0.0;
				}
				100% {
					opacity: 1.0;
				}
			}

			@keyframes gollumgollum {
				0% {
					opacity: 0.0;
				}
				50% {
					opacity: 0.0;
				}
				60% {
					opacity: 1.0;
				}
				80% {
					opacity: 1.0;
				}
				90% {
					opacity: 0.0;
				}
				100% {
					opacity: 0.0;
				}
			}
		}

		@media screen and (min-width: 1400px) {
			.easter-happy-day {
				top: -145px;
			}
		}

		@media screen and (min-width: 1720px) {
			.easter-happy-day {
				top: -157px;
			}
		}

		@media screen and (min-width: 2000px) {
			.easter-happy-day {
				top: -178px;
			}
		}
	</style>
</head>
<body>
	<section id="page">
		<header>
			<h1><a href="https://lib.byu.edu/" class="logo"><img src="//media.lib.byu.edu/assets/images/logo/byu-library-logo-white.png" alt="Harold B. Lee Library" /></a></h1>
		</header>
		<div id="content">
			<div id="message">
				<h2>Page Not Found</h2>

<p>Try the <a href="https://lib.byu.edu/">home page</a> or the <a href="https://lib.byu.edu/site-index/">site index</a>.</p>

			<div id="failquail">
				<img src="//media.lib.byu.edu/assets/images/error/1.0/failquail.png" alt="The Fail Quail" title="The Fail Quail" />
				<div class="easter-happy-day">
					<h3>The Fail Quail has laid an Easter egg!</h3>
					<p>Go to the <a href="https://lib.byu.edu/" target="_blank">library home page</a> and then type in the Konami code.</p>
				</div>
			</div>
		</div>
	</section>
</body>
</html>
